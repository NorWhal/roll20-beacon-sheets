{
  "name": "@r20sd/star-trek-adventures-2e-sheet",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "sandbox-server": "vite --port 7620 --mode staging",
    "sandbox": "run-s build-scss sandbox-server",
    "build": "run-s build-scss build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:local": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress run --e2e'",
    "test:e2e:open:local": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "build-scss": "sass ./src/rolltemplates/styles/host.scss ./public/host.css --no-source-map --no-charset",
    "watch-scss": "sass --watch ./src/rolltemplates/styles/host.scss ./public/host.css --no-source-map --no-charset",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "ci-check": "npm run format && npm run lint && npm run type-check && npm run test:unit && npm run test:e2e:local"
  },
  "dependencies": {
    "@apollo/client": "^3.11.4",
    "@floating-ui/vue": "^1.1.2",
    "@headlessui/vue": "^1.7.22",
    "@roll20-official/beacon-sdk": "^0.1.0",
    "@vueuse/core": "^13.6.0",
    "handlebars": "^4.7.7",
    "jsonpath": "^1.1.1",
    "lodash": "^4.17.21",
    "nanoid": "^5.0.9",
    "pinia": "^2.2.0",
    "uuid": "^9.0.1",
    "vite-svg-loader": "^4.0.0",
    "vue": "^3.5.13",
    "vue-component-library": "^0.0.8",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.2.0",
    "@pinia/testing": "^0.1.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/vue": "^7.0.0",
    "@types/jsdom": "^21.1.0",
    "@types/jsonpath": "^0.2.4",
    "@types/lodash": "^4.14.202",
    "@types/node": "^18.14.2",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/test-utils": "^2.3.0",
    "@vue/tsconfig": "^0.1.3",
    "@vue/typescript-plugin": "2.0.29",
    "cypress": "^13.6.6",
    "eslint": "^9.5.0",
    "jsdom": "^21.1.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.62.1",
    "start-server-and-test": "^2.0.0",
    "typescript": "~4.8.4",
    "vite": "^5.4.0",
    "vite-svg-loader": "^4.0.0",
    "vitest": "^3.2.4",
    "vitest-dom": "^0.1.0",
    "vue-tsc": "^1.2.0"
  }
}
