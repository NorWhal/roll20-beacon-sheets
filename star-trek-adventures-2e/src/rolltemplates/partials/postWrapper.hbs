<rolltemplate class="sta2 sta2--{{type}}">
  <div class="lcars__top">
    <ul class="lcars__top-sidebar">
      {{#each topBarValues}}
        <li>{{this}}</li>
      {{/each}}
    </ul>
    <div class="lcars__top-content">
      <div class="info">
        {{#if characterName}}
          <h6 class="info__name">{{characterName}}</h6>
        {{/if}}
      </div>
    </div>
    <div class="lcars__top-underbar"></div>
  </div>
  <div class="lcars__bottom">
    <ul class="lcars__bottom-sidebar">
      <div class="lcars__sidebar-spacer"></div>
      {{#each bottomBarValues}}
        {{#if this.action}}
          <li>
            {{> rollAction action=this.action classes="lcars__bottom-sidebar-item lcars__bottom-sidebar-item--button" stringifiedResult=../stringifiedResult}}
          </li>
        {{/if}}
        {{#if this.content}}
          <li>
            <span class="lcars__bottom-sidebar-item"> {{this.content}} </span>
          </li>
        {{/if}}
      {{/each}}
    </ul>
    <div class="lcars__bottom-overbar">
      <h6 class="lcars__roll-title">
        {{ rollTitle }}
      </h6>
    </div>
    <div class="lcars__bottom-content">
      {{> @partial-block }}
      {{!-- <div class="roll reroll">
        <button class="reroll__button" data-sheet-action="startReRoll" data-args="{{dice}}"> Reroll </button>
      </div> --}}
    </div>
  </div>
</rolltemplate>